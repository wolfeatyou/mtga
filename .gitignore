# transient runtime state (rewritten every draft)
.draft_hist.json
.draft_watch.json

# python bytecode
__pycache__/
*.pyc

# backups
*.bak

# 17Lands color-pair caches — regenerated on demand from 17lands.com
cache_17l_*.json

# latency-sim artifacts — regenerated from Player.log by draft_sim.py
sim/sim_player.log
sim/sim_state.json

# per-game generated replay outputs (regenerated by replay_*.py)
replay_report.html
replay_moments.html
game4_review.html
